generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model refreshRuns {
  id   Int       @id @default(autoincrement())
  date DateTime? @default(now()) @db.Timestamp(6)
}

model userSummary {
  id            Int        @id @default(autoincrement())
  user_id       String?    @unique
  email         String?
  name          String?
  surname       String?
  week_trans    Int?
  daily_trans   Int?
  monthly_trans Int?
  mp            Boolean?
  country       String?
  phone         String?
  created_at    DateTime?
  last_update   DateTime?  @db.Timestamp(6)
  contacts      contacts[]
}

enum ContactState {
  contacted
  talking
  finalizado
  no_response
}

enum ContactObjective {
  activation
  increase_trans
  MP
}

enum media {
  number
  email
}

enum result {
  fail
  success
}

model contacts {
  id          Int               @id @default(autoincrement())
  user_id     String?
  state       ContactState      @default(contacted)
  start_date  DateTime?         @default(now()) @db.Timestamp(6)
  end_date    DateTime?         @db.Timestamp(6)
  objective   ContactObjective?
  media       media?
  notes       String?
  board_order Float             @default(0)
  user        userSummary?      @relation(fields: [user_id], references: [user_id])
}

model merchant {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  domain     String?
  logo_url   String?
  aliases    String[]  @default([])
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)
  deleted_at DateTime? @db.Timestamp(6)

  @@map("merchants")
}

model metric_daily {
  id                               Int      @id @default(autoincrement())
  date                             DateTime @unique @default(now()) @db.Timestamp(6)
  total_users                      Int?
  new_users                        Int?
  active_users_7d                  Int?
  total_transactions               Int?
  new_transactions                 Int?
  avg_transactions_per_user        Float?
  avg_transactions_per_active_user Float?
  total_integrations               Int?
}
